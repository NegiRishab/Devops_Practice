def gv

pipeline {
    agent any
    tools {
        nodejs 'node-22'
    }

    environment {
        NOTIFY_EMAIL = 'rishabhvicky98@gmail.com'
    }

    stages {
        stage('init') {
            steps {
                script {
                    dir('JenkinsCompletePipeline') {
                        gv = load 'pipeline.groovy'
                    }
                    echo "branch name is ${env.BRANCH_NAME}"
                }
            }
        }
        stage('Test') {
            steps {
                script {
                    dir('JenkinsCompletePipeline') {
                        gv.RunTests()
                    }
                }
            }
        }
        stage('Increment backend version') {
            steps {
                script {
                    dir('JenkinsCompletePipeline') {
                        gv.IncrementBackendVersion()
                    }
                }
            }
        }
        stage('Build backend image') {
            steps {
                script {
                    dir('JenkinsCompletePipeline') {
                        gv.BuildBackendImage()
                    }
                }
            }
        }
        stage('Increment frontend version') {
            steps {
                script {
                    dir('JenkinsCompletePipeline') {
                        gv.IncrementFrontendVersion()
                    }
                }
            }
        }
        stage('Build frontend image') {
            steps {
                script {
                    dir('JenkinsCompletePipeline') {
                        gv.BuildFrontendImage()
                    }
                }
            }
        }
        stage('Deploy to server') {
            when {
                expression {
                    return env.BRANCH_NAME == 'main'
                }
            }
            steps {
                script {
                    dir('JenkinsCompletePipeline') {
                        gv.DeployOnServer()
                    }
                }
            }
        }
        stage('Version bump') {
            steps {
                script {
                    dir('JenkinsCompletePipeline') {
                        gv.VersionBump()
                    }
                }
            }
        }
    }

    post {
        success {
            emailext(
                subject: "SUCCESS: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: """Pipeline succeeded!

Job: ${env.JOB_NAME}
Build: #${env.BUILD_NUMBER}
Branch: ${env.BRANCH_NAME ?: 'N/A'}
Backend image: ${env.BACKEND_IMAGE ?: 'N/A'}
Frontend image: ${env.FRONTEND_IMAGE ?: 'N/A'}

Build URL: ${env.BUILD_URL}
""",
                to: "${env.NOTIFY_EMAIL}"
            )
        }
        failure {
            emailext(
                subject: "FAILED: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: """Pipeline failed!

Job: ${env.JOB_NAME}
Build: #${env.BUILD_NUMBER}
Branch: ${env.BRANCH_NAME ?: 'N/A'}

Check the console output for details:
${env.BUILD_URL}console
""",
                to: "${env.NOTIFY_EMAIL}"
            )
        }
    }
}
